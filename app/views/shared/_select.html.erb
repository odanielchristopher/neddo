<div class="component select">
  <!-- Campo de input -->
  <select
    type="text" 
    id="select" 
    name="select" 
    class="select"
  >
    <option value=""></option>
    <option value="#f2f2f2">
      Branco
    </option>
    <option value="#f2f2f2">
      Branco
    </option>
    <option value="#f2f2f2">
      Branco
    </option>
  </select>

  <!-- Label para o campo -->
  <label for="select" class="label">Cor</label>
  <div class="arrow">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
    <path d="M18 9L12 15L6 9" stroke="#343A40" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <!-- Exibição do erro se existir -->
  <div class="error-span">
    <%= image_tag("cross-circle.svg", alt: "error circle", class: "circle-icon") %>
    <span>Esse campo é obrigatório.</span>
  </div>
</div>
